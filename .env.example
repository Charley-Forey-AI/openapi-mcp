# --- Trimble Agentic AI Platform ---
# Base URL of the Agentic AI Platform Tools API.
# Pick an environment with TRIMBLE_ENV (dev | stage | prod) or set
# TRIMBLE_TOOLS_API_BASE_URL directly to override.
TRIMBLE_ENV=stage
TRIMBLE_TOOLS_API_DEV_BASE_URL=https://tools.dev.trimble-ai.com
TRIMBLE_TOOLS_API_STAGE_BASE_URL=https://tools.stage.trimble-ai.com
# NOTE: The preview OpenAPI MCP routes (`/v1/openapi-servers*`) are not
# served from https://tools.ai.trimble.com (that host returns 404 for those
# paths). The Tool Registry spec in Agentic docs uses tools.stage.trimble-ai.com
# for the Tools API. Use stage or dev for create/list OpenAPI servers until
# Trimble documents a prod Tools host that includes that API.
# TRIMBLE_ENV=prod with TRIMBLE_TOOLS_API_PROD_BASE_URL=https://tools.ai.trimble.com
# will break openapi-mcp; set TRIMBLE_TOOLS_API_BASE_URL to stage explicitly if needed.
TRIMBLE_TOOLS_API_PROD_BASE_URL=https://tools.stage.trimble-ai.com
# When set, TRIMBLE_TOOLS_API_BASE_URL wins over TRIMBLE_ENV — changing only
# TRIMBLE_ENV has no effect if this still points at https://tools.ai.trimble.com.
# Leave unset (or use stage URL) for OpenAPI MCP registration.
# TRIMBLE_TOOLS_API_BASE_URL=https://tools.stage.trimble-ai.com
#
# If Tools API returns 403 "Token audience does not satisfy required API scope":
# the bearer token must be valid for THIS Tools host (stage vs prod audience)
# and include the scopes the platform requires (often `openid tools`). Using
# prod Studio with a stage TRIMBLE_TOOLS_API_BASE_URL commonly causes this;
# use the same environment for Studio and Tools API, or ask Trimble for the
# supported token flow.

# --- Authentication (choose ONE of the three modes) ---
#
# 1. OBO PASSTHROUGH (production, inside Trimble Agent Studio):
#    Leave all of the below blank. The MCP server runs in HTTP/SSE mode and
#    forwards the caller's `Authorization: Bearer <TID-OBO-token>` header
#    directly to the Agentic AI Platform on every tool call.
#
# 2. STATIC BEARER TOKEN (local dev / stdio):
#    Set a long-lived TID access token here. Used only when the incoming
#    request has no Authorization header.
TRIMBLE_ACCESS_TOKEN=

# 3. CLIENT CREDENTIALS (service-to-service):
#    Set these to have the MCP mint its own access token against Trimble ID.
#    Token is cached in-memory and refreshed automatically.
#
#    IMPORTANT: Trimble ID has SEPARATE tenants per environment. Clients
#    created in the staging Cloud Console (console.stage.api.trimblecloud.com)
#    only exist in the staging TID tenant and must mint tokens at
#    https://stage.id.trimble.com/oauth/token. Prod clients use id.trimble.com.
#
#    Leave TRIMBLE_TOKEN_URL blank and the server will pick the right endpoint
#    automatically based on TRIMBLE_ENV (dev/stage -> stage TID, prod -> prod TID).
TRIMBLE_CLIENT_ID=
TRIMBLE_CLIENT_SECRET=
# TRIMBLE_TOKEN_URL=https://stage.id.trimble.com/oauth/token  # override only if auto-pick is wrong
# Space-separated OAuth scopes. `openid tools` is the minimum to call
# /v1/openapi-servers/* on the Agentic AI Platform Tools API. Add more scopes
# (agents, kb, models, kb-ingest, profile, etc.) only if the client has been
# granted them in the Trimble Cloud Console for this application.
# Quote the value so the space is preserved (systemd EnvironmentFile and dotenv).
TRIMBLE_SCOPES="openid tools"

# --- MCP transport ---
# stdio (for local CLI / Claude Desktop style clients) or "http" for
# Trimble Agent Studio and other remote MCP hosts that need OBO passthrough.
MCP_TRANSPORT=http
MCP_HOST=127.0.0.1
MCP_PORT=8754
# Public URL path the MCP endpoint lives on. Must match what nginx routes.
# Default assumes nginx location is `/mcp/openapi-mcp/`.
MCP_PATH=/mcp/openapi-mcp

# --- Workflow tuning ---
# Max seconds to wait for parse_status to transition out of pending/queued/parsing.
PARSE_POLL_TIMEOUT_SECONDS=120
PARSE_POLL_INTERVAL_SECONDS=2

# Max bytes of OpenAPI spec we'll download from a user-supplied URL (default 1000 MiB).
MAX_SPEC_BYTES=1048576000
# Hint for analyze_openapi_spec_url (exceeds_platform_limit). Match executor cap.
# PLATFORM_MAX_OPENAPI_OPERATIONS=50
# Max size (bytes) for spec_json in export_trimmed_openapi_spec inline response.
# MAX_TRIMMED_SPEC_EXPORT_BYTES=2000000
#
# If true, create_mcp_from_openapi_url fails locally when the spec has more
# operations than PLATFORM_MAX_OPENAPI_OPERATIONS and no tool_filter and no
# acknowledge_openapi_operation_limit (avoids a doomed register/upload/parse).
# CREATE_PREFLIGHT_ENFORCE=false
#
# If true (default), create with tool_filter runs include_tags / include_paths /
# include_operations through local path trimming before SAS upload when the
# spec exceeds PLATFORM_MAX — required because the platform counts ops on the
# file before tool_filter. Set to false to always upload the raw file.
# CREATE_AUTO_TRIM_ON_TOOL_FILTER=true
